{
  "version": 2,
  "installCommand": "npm install --omit=dev",
  "functions": {
    "api/index.js": {
      "maxDuration": 10,
      "memory": 1024,
      "excludeFiles": "node_modules/{onnxruntime-node,@img,sharp}/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
