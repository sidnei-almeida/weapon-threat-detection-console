# Copie para .env local (não commitar)
PORT=3001
YOLO_MODEL=fp32

# Taxa alvo de inferência no feed (1–60 FPS). O FPS real depende do hardware.
INFERENCE_FPS=12

# Opcional — usar Roboflow na Vercel se o cold start do ONNX estourar 10s
# DETECTION_BACKEND=roboflow
# ROBOFLOW_API_KEY=
# ROBOFLOW_PROJECT_WEAPON=
# ROBOFLOW_PROJECT_MASK=
