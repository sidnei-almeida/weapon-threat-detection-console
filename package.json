    "optimize:videos": "bash scripts/optimize-videos.sh"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "onnxruntime-node": "^1.26.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3"
  }
}
