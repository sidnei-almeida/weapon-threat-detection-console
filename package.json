{
  "name": "weapon-threat-detection-console",
  "version": "0.1.0",
  "description": "Real-time computer vision console for detecting weapon-related threat objects using a YOLO object detection model.",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "node test/integration.test.js",
    "inspect:onnx": "node scripts/inspect-onnx-models.js",
    "test:image": "node scripts/test-image-inference.js",
    "test:threat": "node scripts/test-threat-batch.js",
    "test:video": "node scripts/test-video-inference.js",
